# ── Required environment variables ──────────────────────────────────────────
#
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
#
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI — used for embeddings (text-embedding-3-small) and chat (gpt-4o)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Cohere — used for reranking search results (rerank-multilingual-v3.0)
# Get yours at: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=...

# Groq — used for LLM inference (Llama 3.3 70B, free tier available)
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Supabase PostgreSQL connection string
#
# How to get it:
#   1. Go to your Supabase project → Project Settings → Database
#   2. Select "Session mode" connection string (port 5432)
#   3. Copy the URI, e.g.:
#        postgresql://postgres:[YOUR-PASSWORD]@db.[ref].supabase.co:5432/postgres
#   4. Replace the scheme with postgresql+psycopg:// for LangChain PGVector:
#        postgresql+psycopg://postgres:[YOUR-PASSWORD]@db.[ref].supabase.co:5432/postgres
#
# The app automatically derives the asyncpg URL for SQLAlchemy from this value.
DATABASE_URL=postgresql+psycopg://postgres:[YOUR-PASSWORD]@db.[project-ref].supabase.co:5432/postgres
